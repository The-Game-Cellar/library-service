# Server
LIBRARY_SERVICE_PORT=8082

# Database (PostgreSQL on port 5433)
# Use 127.0.0.1 rather than localhost so the JDBC driver always picks the IPv4
# loopback. On Windows + Docker Desktop the IPv6 loopback (::1) is sometimes
# bound by wslrelay but refuses connections, which makes localhost resolution
# unreliable for Postgres clients.
LIBRARY_DB_URL=jdbc:postgresql://127.0.0.1:5433/library_db
LIBRARY_DB_USERNAME=postgres
LIBRARY_DB_PASSWORD=your-password-here

# Hibernate DDL mode. Default in application.yaml is `validate` (prod-safe — service refuses
# to start on schema mismatch). Local dev typically wants `update` so Hibernate auto-creates
# new entity columns/tables without a manual ALTER step. NEVER set to `update` in production
# — silent schema mutation on startup is a security/correctness hazard. When versioned
# migrations land, this stays `validate` everywhere and migrations own all DDL.
DDL_AUTO=update

# Keycloak
KEYCLOAK_ISSUER_URI=http://localhost:8080/realms/game-cellar

# Game Service
GAME_SERVICE_URL=http://localhost:8081
GAME_SERVICE_CONNECT_TIMEOUT=2000
GAME_SERVICE_READ_TIMEOUT=5000
